---
// Vercel / Linear Style Hero Component
---
<section class="relative min-h-[85vh] flex flex-col justify-center overflow-hidden bg-black">
  <!-- Subtly animated background grid (Optional Vercel style) -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#333_1px,transparent_1px),linear-gradient(to_bottom,#333_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-20"></div>

  <div class="relative max-w-5xl mx-auto px-6 sm:px-8 lg:px-12 w-full z-10 pt-20">
    <div class="max-w-3xl animate-slide-up">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#111] border border-[#333] mb-8">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-zinc-300 text-xs font-mono uppercase tracking-widest">Available for new opportunities</span>
      </div>

      <!-- Main heading -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-white leading-[1.1] mb-6">
        Architecting robust <br/>
        <span class="text-zinc-500">Enterprise Integrations & AI</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl mb-12 leading-relaxed">
        Middle+/Senior Software Engineer focused on Zero Data Leak AI pipelines, 
        idempotent ETL processes, and solving real business problems with measurable impact. 
        I don't just write code — I deliver reliable systems.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/cases/" class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-white text-black font-medium text-sm transition-transform hover:scale-[1.02] active:scale-[0.98]">
          View Engineering Cases
        </a>
        <a href="#github" class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-[#111] border border-[#333] text-white font-medium text-sm hover:bg-[#222] transition-colors">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
          </svg>
          GitHub Profile
        </a>
      </div>
    </div>
  </div>
</section>
