---
// Hero Section Component
---
<section class="relative min-h-[90vh] flex items-center overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-dark-900 via-dark-800 to-dark-900" />
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-accent/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3" />
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent-dark/5 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4" />
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
    <div class="max-w-4xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent/10 border border-accent/20 mb-8">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse" />
        <span class="text-accent text-sm font-medium">Доступен для новых проектов</span>
      </div>

      <!-- Main heading -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold leading-tight mb-6">
        <span class="text-white">Проектирование надежных</span>
        <br />
        <span class="gradient-text">Enterprise-интеграций & AI</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mb-10 leading-relaxed">
        Middle+/Senior Software Engineer. Фокус на Zero Data Leak пайплайнах, идемпотентных ETL процессах и решении реальных задач бизнеса с измеримым результатом.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/cases/"
          class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-accent hover:bg-accent-dark text-dark-900 font-semibold text-base transition-all duration-200 group"
        >
          Посмотреть инженерные кейсы
          <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="https://github.com/AI-Business-System"
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 text-white font-medium text-base transition-all duration-200"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
          </svg>
          GitHub Профиль
        </a>
      </div>
    </div>
  </div>
</section>
