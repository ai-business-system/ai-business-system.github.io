---
import Layout from '../../components/Layout.astro';
import decisions from '../../data/decisions.json';
---

<Layout title="Engineering Decisions | AiOps & Automation" description="Почему SOAP, PostgreSQL, RAG и локальная обработка.">
  <div class="py-24 lg:py-32 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6 tracking-tight">Engineering Decisions</h1>
      <p class="text-xl text-zinc-400 max-w-2xl leading-relaxed">
        Архитектурные выборы и обоснование используемых технологий в production. Не гнаться за хайпом, а решать задачи бизнеса.
      </p>
    </div>

    <div class="space-y-8">
      {decisions.map((d) => (
        <article class="glass p-8 md:p-10 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-1 h-full bg-zinc-800 group-hover:bg-emerald-500 transition-colors"></div>
          
          <div class="flex items-center gap-3 mb-4">
            <span class="px-3 py-1 rounded-full bg-[#111] border border-[#333] text-zinc-300 text-xs font-mono">{d.category}</span>
          </div>
          
          <h2 class="text-2xl font-bold text-white mb-4">{d.title}</h2>
          
          <p class="text-zinc-300 leading-relaxed text-base whitespace-pre-line mb-6">
            {d.description}
          </p>
          
          {d.tech && d.tech.length > 0 && (
            <div class="flex flex-wrap gap-2 pt-6 border-t border-zinc-800/50">
              {d.tech.map(t => (
                <span class="text-xs font-mono text-zinc-500">#{t.toLowerCase()}</span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</Layout>
