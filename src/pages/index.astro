---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import cases from '../data/cases.json';
---

<Layout title="Senior Software Engineer | AiOps & Automation" description="Middle+/Senior Software Engineer Portfolio">
  <Hero />
  
  <!-- Key Projects Preview -->
  <section class="py-24 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-12">
        <div>
          <h2 class="text-3xl font-bold text-white mb-4 tracking-tight">Ключевые проекты</h2>
          <p class="text-gray-400 max-w-xl">Детальный разбор production-архитектур, ETL-пайплайнов и внедрения RAG.</p>
        </div>
        <a href="/cases/" class="hidden sm:inline-flex text-gray-400 hover:text-white transition-colors text-sm font-medium">
          Посмотреть все {cases.length} кейсов &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {cases.slice(0, 4).map((c) => (
          <a href={`/cases/${c.id}`} class="group block p-8 rounded-2xl glass hover:border-accent/50 transition-all duration-300">
            <div class="flex justify-between items-start mb-6">
              <span class="px-2.5 py-1 rounded-md bg-white/5 border border-white/10 text-gray-400 text-xs font-mono">{c.category}</span>
              <svg class="w-5 h-5 text-gray-600 group-hover:text-accent transition-colors -rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3 group-hover:text-accent transition-colors">{c.title}</h3>
            <p class="text-gray-400 text-sm mb-6 line-clamp-3">{c.problem}</p>
            <div class="flex flex-wrap gap-2">
              {c.tags.map((t) => (
                <span class="text-gray-500 text-xs font-mono">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center sm:hidden">
        <a href="/cases/" class="inline-flex text-gray-400 hover:text-white transition-colors text-sm font-medium">
          Посмотреть все кейсы &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Engineering Philosophy / Decisions Preview -->
  <section class="py-24 border-t border-white/5 relative">
    <div class="absolute inset-0 bg-accent/5 blur-[100px] rounded-full w-1/2 h-1/2 top-1/4 left-1/4"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-6 tracking-tight">Инженерная философия</h2>
      <p class="text-gray-400 max-w-2xl mx-auto mb-10 text-lg">
        Я верю в идемпотентные процессы, архитектуру Zero Data Leak и выбор "скучных" технологий (PostgreSQL, SOAP), когда они лучше всего решают задачи бизнеса.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/decisions/" class="inline-flex items-center justify-center px-6 py-3 rounded-xl glass hover:bg-white/10 text-white font-medium text-sm transition-all">
          Инженерные решения (Почему X?)
        </a>
        <a href="/lessons/" class="inline-flex items-center justify-center px-6 py-3 rounded-xl glass hover:bg-white/10 text-white font-medium text-sm transition-all">
          Lessons Learned
        </a>
      </div>
    </div>
  </section>
</Layout>
