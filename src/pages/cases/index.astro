---
import Layout from '../../components/Layout.astro';
import cases from '../../data/cases.json';
---

<Layout title="Инженерные кейсы | AiOps & Automation" description="Глубокий разбор production-проектов и интеграций.">
  <div class="py-24 lg:py-32 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6 tracking-tight">Инженерные кейсы</h1>
      <p class="text-xl text-gray-400 max-w-2xl leading-relaxed">
        Реальные production-проекты и архитектурные решения. Без "воды" — только проблемы, решения и измеримый результат.
      </p>
    </div>

    <div class="space-y-6">
      {cases.map((c) => (
        <a href={`/cases/${c.id}`} class="group block glass p-8 md:p-10 hover:border-accent/50 transition-colors">
          <div class="flex flex-col md:flex-row md:items-start justify-between gap-6">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-4">
                <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10 text-gray-300 text-xs font-mono">{c.category}</span>
                <span class="text-gray-500 text-sm">{c.status === 'production' ? 'Production' : 'MVP'}</span>
              </div>
              <h2 class="text-2xl font-bold text-white mb-4 group-hover:text-accent transition-colors">{c.title}</h2>
              <p class="text-gray-400 leading-relaxed mb-6 line-clamp-2">{c.problem}</p>
              
              <div class="flex flex-wrap gap-2">
                {c.tags.map(t => (
                  <span class="text-xs font-mono text-gray-500">#{t.toLowerCase()}</span>
                ))}
              </div>
            </div>
            
            <div class="hidden md:flex items-center justify-center w-12 h-12 rounded-full border border-white/10 group-hover:border-accent/50 group-hover:bg-accent/10 text-gray-500 group-hover:text-accent transition-all">
              <svg class="w-5 h-5 -rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
