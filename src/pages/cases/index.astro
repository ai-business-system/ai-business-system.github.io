---
import Layout from '../../components/Layout.astro';
import cases from '../../data/cases.json';
---

<Layout title="Engineering Cases | AiOps & Automation" description="Deep dives into production architectures and integrations.">
  <div class="py-24 lg:py-32 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6 tracking-tight">Engineering Cases</h1>
      <p class="text-xl text-zinc-400 max-w-2xl leading-relaxed">
        Real production projects and architectural deep dives. No fluff, just problems, solutions, and measurable impact.
      </p>
    </div>

    <div class="space-y-6">
      {cases.map((c) => (
        <a href={`/cases/${c.id}`} class="group block glass p-8 md:p-10 hover:border-zinc-500 transition-colors">
          <div class="flex flex-col md:flex-row md:items-start justify-between gap-6">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-4">
                <span class="px-3 py-1 rounded-full bg-[#111] border border-[#333] text-zinc-300 text-xs font-mono">{c.category}</span>
                <span class="text-zinc-500 text-sm">{c.status === 'production' ? 'Production' : 'MVP'}</span>
              </div>
              <h2 class="text-2xl font-bold text-white mb-4 group-hover:text-emerald-400 transition-colors">{c.title}</h2>
              <p class="text-zinc-400 leading-relaxed mb-6 line-clamp-2">{c.problem}</p>
              
              <div class="flex flex-wrap gap-2">
                {c.tags.map(t => (
                  <span class="text-xs font-mono text-zinc-500">#{t.toLowerCase()}</span>
                ))}
              </div>
            </div>
            
            <div class="hidden md:flex items-center justify-center w-12 h-12 rounded-full border border-zinc-800 group-hover:border-emerald-500/50 group-hover:bg-emerald-500/10 text-zinc-600 group-hover:text-emerald-400 transition-all">
              <svg class="w-5 h-5 -rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
