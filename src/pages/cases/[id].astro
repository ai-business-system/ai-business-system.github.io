---
import Layout from '../../components/Layout.astro';
import cases from '../../data/cases.json';

export async function getStaticPaths() {
  return cases.map((c) => {
    return {
      params: { id: c.id },
      props: { caseItem: c },
    };
  });
}

const { caseItem } = Astro.props;
---

<Layout title={`${caseItem.title} | AiOps & Automation`} description={caseItem.subtitle}>
  <div class="py-24 lg:py-32 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mb-12 animate-fade-in">
      <div class="flex items-center gap-3 mb-6">
        <span class="px-3 py-1 rounded-full bg-white/10 text-white text-xs font-mono">{caseItem.category}</span>
        <span class="text-zinc-500 text-sm">{caseItem.status === 'production' ? 'Production' : 'MVP'}</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white mb-6 leading-tight">
        {caseItem.title}
      </h1>
      <p class="text-xl text-zinc-400 leading-relaxed">
        {caseItem.problem}
      </p>
    </div>

    <!-- Metrics / Result Summary -->
    {caseItem.result && (
      <div class="glass p-8 mb-16 animate-slide-up" style="animation-delay: 0.1s">
        <h3 class="text-xs font-mono text-zinc-500 uppercase tracking-widest mb-4">The Impact</h3>
        <p class="text-zinc-300 whitespace-pre-line leading-relaxed">{caseItem.result}</p>
      </div>
    )}

    <!-- Architecture & Pipeline -->
    {caseItem.architecture && caseItem.architecture.diagram_mermaid && (
      <div class="mb-16 animate-slide-up" style="animation-delay: 0.2s">
        <h2 class="text-2xl font-semibold text-white mb-6">Architecture & Pipeline</h2>
        <div class="glass p-8 overflow-x-auto">
          <div class="mermaid text-center">
            {caseItem.architecture.diagram_mermaid}
          </div>
        </div>
      </div>
    )}

    <!-- Tech Stack -->
    <div class="mb-16 animate-slide-up" style="animation-delay: 0.3s">
      <h2 class="text-2xl font-semibold text-white mb-6">Technology Stack</h2>
      <div class="flex flex-wrap gap-2">
        {caseItem.tech.map((t) => (
          <span class="px-4 py-2 rounded-lg bg-[#111] border border-[#333] text-zinc-300 text-sm font-mono hover:border-zinc-500 transition-colors">{t}</span>
        ))}
      </div>
    </div>

    <!-- Images / Screenshots -->
    {caseItem.images && caseItem.images.length > 0 && (
      <div class="mb-16 animate-slide-up" style="animation-delay: 0.4s">
        <h2 class="text-2xl font-semibold text-white mb-6">Interface & Evidence</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {caseItem.images.map((img) => (
            <a href={img} target="_blank" rel="noopener noreferrer" class="block rounded-xl overflow-hidden border border-zinc-800 hover:border-zinc-600 transition-colors">
              <img src={img} alt="Скриншот проекта" class="w-full h-auto object-cover" loading="lazy" />
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Lessons Learned -->
    {caseItem.lessons_text && caseItem.lessons_text.length > 0 && (
      <div class="mb-16 animate-slide-up" style="animation-delay: 0.5s">
        <h2 class="text-2xl font-semibold text-white mb-6">Lessons Learned</h2>
        <div class="space-y-6">
          {caseItem.lessons_text.map((lesson) => (
            <div class="glass p-6">
              <h4 class="text-white font-medium mb-2">{lesson.title}</h4>
              <p class="text-zinc-400 text-sm leading-relaxed">{lesson.description}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Back to Cases -->
    <div class="mt-20 pt-8 border-t border-zinc-900 text-center">
      <a href="/cases/" class="inline-flex items-center text-zinc-400 hover:text-white transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to all projects
      </a>
    </div>

  </div>
</Layout>
