---
import Layout from '../../components/Layout.astro';
import aboutData from '../../data/about.json';
import { Content as AboutContent } from './content.md';
---

<Layout title="Обо мне | AiOps & Automation" description={aboutData.summary}>
  <div class="py-24 lg:py-32 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row gap-12 items-start">
      
      <!-- Photo -->
      {aboutData.photo && (
        <div class="md:w-1/3 shrink-0">
          <div class="glass p-2 rounded-2xl overflow-hidden sticky top-24">
            <img src={aboutData.photo} alt="Photo" class="w-full h-auto rounded-xl grayscale hover:grayscale-0 transition-all duration-700" />
          </div>
        </div>
      )}
      
      <!-- Content -->
      <div class="md:w-2/3 markdown-content">
        <AboutContent />
      </div>
      
    </div>
  </div>
</Layout>

<style is:global>
  .markdown-content h1 { @apply text-4xl sm:text-5xl font-bold text-white mb-8 mt-12 tracking-tight; }
  .markdown-content h1:first-child { @apply mt-0; }
  .markdown-content h2 { @apply text-2xl sm:text-3xl font-bold text-white mb-6 mt-12; }
  .markdown-content h3 { @apply text-xl font-bold text-white mb-4 mt-8; }
  .markdown-content p { @apply text-gray-400 text-lg leading-relaxed mb-6; }
  .markdown-content ul { @apply list-disc list-inside text-gray-400 text-lg mb-6 space-y-2 ml-2; }
  .markdown-content li { @apply text-gray-400; }
  .markdown-content blockquote { @apply border-l-4 border-accent pl-6 py-2 my-8 italic text-gray-300 bg-white/5 rounded-r-xl; }
  .markdown-content hr { @apply border-white/10 my-12; }
  .markdown-content code { @apply font-mono bg-white/10 px-2 py-1 rounded text-sm text-gray-300; }
  .markdown-content pre { @apply bg-[#111] p-6 rounded-xl overflow-x-auto border border-white/10 my-8; }
  .markdown-content pre code { @apply bg-transparent p-0 text-sm text-gray-300; }
</style>
