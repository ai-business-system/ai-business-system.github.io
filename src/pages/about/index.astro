---
import Layout from '../../components/Layout.astro';
import { siteConfig } from '../../config/site.js';

const competencies = [
  'Автоматизация бизнес-процессов',
  'AI-интеграции и чат-боты',
  'ERP / CRM интеграции',
  'Data cleanup и нормализация',
  'Excel-автоматизация',
  'Telegram / WhatsApp боты',
  'Семантический поиск и RAG',
  'Разработка API и интеграций',
  'Бизнес-аналитика и отчётность',
];

const techStack = [
  'Python', 'FastAPI', 'Supabase', 'PostgreSQL', 'pgvector',
  'Telegram Bot API', 'WhatsApp Business API', 'Excel / OpenPyXL',
  'LLM / OpenAI / LiteLLM', 'REST APIs', 'Webhooks',
  'Pandas', 'SQL', 'Git', 'Linux',
];
---

<Layout title="Обо мне — AiOps & Automation" description="Практичный специалист на стыке IT, бизнеса и автоматизации">
  <div class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Hero -->
      <div class="max-w-4xl mb-16">
        <p class="text-accent text-sm font-semibold uppercase tracking-wider mb-3">Обо мне</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-8">
          Практик, а не теоретик
        </h1>
      </div>

      <!-- Bio section -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-20">
        <!-- Photo placeholder -->
        <div class="lg:col-span-1">
          <div class="aspect-[3/4] glass rounded-2xl flex items-center justify-center">
            <div class="text-center">
              <div class="w-24 h-24 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
                <svg class="w-12 h-12 text-accent/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <p class="text-gray-500 text-sm">Фото</p>
            </div>
          </div>
        </div>

        <!-- Bio text -->
        <div class="lg:col-span-2">
          <div class="space-y-6 text-gray-300 leading-relaxed">
            <p>
              Я — бакалавр информационных систем. Мой путь в IT начался ещё во времена MS-DOS и Windows 95. 
              Однако значительную часть карьеры я провёл в FMCG и продажах, где прошёл путь от торгового 
              представителя до супервайзера.
            </p>
            <p>
              Работая в операционном бизнесе, я постоянно сталкивался с ручным хаосом, потерями времени и 
              неэффективными процессами. Именно это сформировало мой подход к автоматизации: технологии 
              должны решать реальные задачи бизнеса, а не существовать ради модных слов.
            </p>
            <p>
              Сегодня я занимаюсь автоматизацией процессов, интеграциями, AI-консультантами и системами, 
              которые помогают компаниям снижать рутину, упрощать работу с данными и повышать прозрачность 
              процессов.
            </p>
          </div>

          <!-- Key quote -->
          <div class="mt-10 glass p-6 border-l-4 border-accent">
            <p class="text-white text-lg italic leading-relaxed">
              «Я говорю с бизнесом на языке денег и времени, а с IT — на языке архитектуры и кода. 
              Это позволяет перевести задачу компании в работающее решение без потери смысла.»
            </p>
          </div>
        </div>
      </div>

      <!-- Competencies -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20">
        <div>
          <h2 class="text-2xl font-bold text-white mb-6">Компетенции</h2>
          <div class="space-y-3">
            {competencies.map((c) => (
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-300">{c}</span>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-white mb-6">Технологический стек</h2>
          <div class="flex flex-wrap gap-2">
            {techStack.map((t) => (
              <span class="px-4 py-2 rounded-lg bg-white/5 text-gray-300 text-sm font-mono hover:bg-white/10 transition-colors cursor-default">
                {t}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Approach philosophy -->
      <div class="glass p-8 lg:p-12">
        <h2 class="text-2xl font-bold text-white mb-6">Почему мне можно доверять</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-lg font-semibold text-white mb-2">Знаю бизнес изнутри</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              10+ лет в операционных процессах FMCG. Я знаю, как выглядят реальные проблемы, 
              а не теоретические кейсы из книг.
            </p>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-white mb-2">Продумаю до кода</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Не начинаю с написания кода. Сначала анализирую процессы, оцениваю целесообразность, 
              ищу более простые альтернативы.
            </p>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-white mb-2">Говорю «нет» когда надо</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Если автоматизация не окупится — скажу прямо. Моя репутация дороже одного заказа.
            </p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-12 text-center">
        <a href="/#contacts" class="inline-flex items-center px-8 py-4 rounded-xl bg-accent hover:bg-accent-dark text-dark-900 font-semibold transition-all duration-200">
          Обсудить задачу
        </a>
      </div>
    </div>
  </div>
</Layout>
